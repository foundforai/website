# Copy this file to .env.local for local reference (gitignored).
# These values must ALSO be set in Vercel: Project Settings > Environment Variables
# (Production, Preview, and Development scopes).
#
# Local Vite dev (`npm run dev`) does not run the api/* serverless functions, so
# .env.local is informational here — Vercel reads from its own env-var store
# at runtime in production.

INDEXNOW_KEY=a2c11531e7de47a08dfe4cb47d120610
INDEXNOW_KEY_LOCATION=https://foundforai.com/a2c11531e7de47a08dfe4cb47d120610.txt
INDEXNOW_HOST=foundforai.com

# Generate fresh: `openssl rand -hex 16`. Used to authenticate the manual
# /api/indexnow/manual endpoint and also accepted by the cron endpoint.
ADMIN_API_KEY=replace_with_32_char_hex_string
