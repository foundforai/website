{
  "cleanUrls": true,
  "redirects": [
    { "source": "/search", "destination": "/", "statusCode": 301 },
    { "source": "/reports/:path*", "destination": "/", "statusCode": 301 },
    { "source": "/reports", "destination": "/", "statusCode": 301 },
    { "source": "/readiness-report", "destination": "/", "statusCode": 301 },
    { "source": "/purchase-complete", "destination": "/", "statusCode": 301 }
  ],
  "rewrites": [
    { "source": "/fix-plan/request", "destination": "/fix-plan-request" },
    { "source": "/fix-plan/thanks", "destination": "/fix-plan-thanks" }
  ],
  "crons": [
    { "path": "/api/cron/indexnow", "schedule": "0 */6 * * *" }
  ]
}
