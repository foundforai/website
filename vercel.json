{
  "redirects": [
    { "source": "/search", "destination": "/", "statusCode": 301 },
    { "source": "/reports/:path*", "destination": "/", "statusCode": 301 },
    { "source": "/reports", "destination": "/", "statusCode": 301 },
    { "source": "/readiness-report", "destination": "/", "statusCode": 301 },
    { "source": "/purchase-complete", "destination": "/", "statusCode": 301 }
  ],
  "rewrites": [
    { "source": "/ai-visibility", "destination": "/ai-visibility.html" },
    { "source": "/talk-to-a-human", "destination": "/talk-to-a-human.html" },
    { "source": "/fix-plan", "destination": "/fix-plan.html" },
    { "source": "/fix-plan/request", "destination": "/fix-plan-request.html" },
    { "source": "/fix-plan/thanks", "destination": "/fix-plan-thanks.html" },
    { "source": "/((?!.*\\.).*)", "destination": "/index.html" }
  ]
}
