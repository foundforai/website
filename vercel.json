{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Link",
          "value": "</llms.txt>; rel=\"describedby\", </llms-full.txt>; rel=\"describedby\", </sitemap.xml>; rel=\"sitemap\", </robots.txt>; rel=\"robots\", </.well-known/api-catalog>; rel=\"api-catalog\""
        },
        {
          "key": "Vary",
          "value": "Accept"
        }
      ]
    },
    {
      "source": "/.well-known/api-catalog",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/linkset+json"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Vary",
          "value": "Accept"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/search", "destination": "/", "statusCode": 301 },
    { "source": "/reports/:path*", "destination": "/", "statusCode": 301 },
    { "source": "/reports", "destination": "/", "statusCode": 301 },
    { "source": "/readiness-report", "destination": "/", "statusCode": 301 },
    { "source": "/purchase-complete", "destination": "/", "statusCode": 301 },
    { "source": "/blog/blue-apple-ai-recommended-produce-freshness", "destination": "/blog/bluapple-ai-recommended-produce-freshness", "statusCode": 301 },
    { "source": "/talk-to-a-human", "destination": "/book-call", "statusCode": 301 }
  ],
  "rewrites": [
    { "source": "/fix-plan/request", "destination": "/fix-plan-request" },
    { "source": "/fix-plan/thanks", "destination": "/fix-plan-thanks" },
    { "source": "/api/analyze", "destination": "https://scorecard.foundforai.com/api/analyze" }
  ],
  "crons": [
    { "path": "/api/cron/indexnow", "schedule": "0 */6 * * *" }
  ]
}
